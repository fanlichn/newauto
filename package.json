{
  "name": "autojs-web-studio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "lint": "tsc --noEmit",
    "start": "node dist/server.cjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^0.435.0",
    "motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.2",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.0.0-beta.2",
    "tsx": "^4.23.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.1"
  }
}
